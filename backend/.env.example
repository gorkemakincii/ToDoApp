# Copy these into Render → Environment Variables
# (Do NOT commit the real values)

# From Neon dashboard → Connection string (Npgsql format)
DATABASE_URL=Host=ep-xxx.us-east-2.aws.neon.tech;Database=neondb;Username=neondb_owner;Password=xxx;SSL Mode=Require;Trust Server Certificate=true

# Vercel frontend URL (set after frontend is deployed)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

ASPNETCORE_ENVIRONMENT=Production
